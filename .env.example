# GratefulCo Environment Variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to source control.

# ------------------------------------------------
# Supabase (required)
# ------------------------------------------------
# From: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Server-side only (used in Edge Functions / API routes)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------------------------------------------------
# Anthropic (for AI weekly insights — Phase 3)
# ------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------
# App config
# ------------------------------------------------
# Restrict CORS to your deployed domain
ALLOWED_ORIGIN=https://your-vercel-domain.vercel.app
